{
  "name": "obsidian-vox",
  "version": "1.0.1",
  "description": "Reads your Obsidian notes aloud with neural text-to-speech.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "lint": "eslint src --max-warnings=0",
    "build": "npm run lint && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "tts",
    "text-to-speech",
    "voice",
    "elevenlabs"
  ],
  "author": "danialkalbasi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.59.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "^1.7.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
